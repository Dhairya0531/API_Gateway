{
  "title": "API Gateway Metrics",
  "panels": [
    {
      "title": "Total Requests per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(gateway_requests_total[1m])) by (method, status)",
          "legendFormat": "{{method}} - {{status}}"
        }
      ]
    },
    {
      "title": "Request Latency (99th Percentile)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 Latency (s)"
        }
      ]
    },
    {
      "title": "Upstream Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(gateway_upstream_active_connections) by (service, upstream_url)",
          "legendFormat": "{{service}} - {{upstream_url}}"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 30,
  "timezone": "browser"
}
